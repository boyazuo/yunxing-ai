# 云行 AI Docker 部署环境变量
# 复制为 .env 后按需修改：cp .env.docker.example .env

# ---------- 通用 ----------
COMPOSE_PROJECT_NAME=yunxing-ai

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=yxboot
MYSQL_USER=root
MYSQL_PASSWORD=root123456

# ---------- Redis ----------
REDIS_PASSWORD=redis123456

# ---------- JWT ----------
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ---------- AI 服务（必填，否则对话与向量检索不可用）----------
AI_CHAT_API_KEY=
AI_EMBEDDING_API_KEY=

# AI 可选配置
AI_CHAT_PROVIDER=zhipuai
AI_CHAT_MODEL=glm-4-flash
AI_EMBEDDING_PROVIDER=dashscope
AI_EMBEDDING_MODEL=text-embedding-v4

# ---------- 前端 ----------
# 浏览器访问的后端 API 地址（需与对外暴露的 api 端口一致）
# 开发模式（docker-compose.yml）：http://localhost:8080/v1/api
# 生产模式（docker-compose.prod.yml + Nginx）：http://localhost/v1/api 或你的域名
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/v1/api
# 开发模式：http://localhost:3000 | 生产模式（Nginx）：http://localhost 或你的域名
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# 后端 CORS 允许的前端来源（多个用英文逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:3000

# 本地上传文件的访问 URL 前缀
UPLOAD_URL_PREFIX=http://localhost:8080/

# ---------- 邮件（可选，邀请功能需要）----------
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ---------- 阿里云 OSS（可选，使用 OSS 存储时取消 compose 中 api 的 local 挂载并改 application-docker）----------
# OSS_ENDPOINT=
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=
